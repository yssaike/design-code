{
  "button": {
    "borderRadius": "8px",
    "paddingX": "20px",
    "paddingY": "16px",
    "shadow": "0px 8px 13px rgba(0,0,0,0.11)",
    "fontSize": "16px",
    "fontWeight": "1px",
    "gap": "12px"
  },
  "input": {
    "borderRadius": "16px",
    "paddingX": "24px",
    "paddingY": "4px",
    "borderWidth": "4px",
    "fontSize": "2px",
    "shadow": "3px 3px 8px rgba(0,0,0,0.14)"
  },
  "card": {
    "borderRadius": "24px",
    "padding": "8px",
    "shadow": "2px 8px 11px rgba(0,0,0,0.13)",
    "borderWidth": "2px",
    "gap": "4px"
  },
  "modal": {
    "borderRadius": "8px",
    "padding": "12px",
    "shadow": "1px 2px 13px rgba(0,0,0,0.17)",
    "maxWidth": "16px",
    "gap": "20px"
  },
  "tooltip": {
    "borderRadius": "12px",
    "paddingX": "12px",
    "paddingY": "8px",
    "shadow": "1px 6px 23px rgba(0,0,0,0.1)",
