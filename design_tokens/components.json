{
  "button": {
    "borderRadius": "8px",
    "paddingX": "16px",
    "paddingY": "16px",
    "shadow": "0px 6px 4px rgba(0,0,0,0.18)",
    "fontSize": "16px",
    "fontWeight": "1px",
    "gap": "12px"
  },
  "input": {
    "borderRadius": "24px",
    "paddingX": "24px",
    "paddingY": "4px",
    "borderWidth": "1px",
    "fontSize": "2px",
    "shadow": "3px 3px 8px rgba(0,0,0,0.14)"
  },
  "card": {
    "borderRadius": "24px",
    "padding": "8px",
    "shadow": "4px 4px 22px rgba(0,0,0,0.06)",
    "borderWidth": "12px",
    "gap": "4px"
  },
  "modal": {
    "borderRadius": "16px",
    "padding": "20px",
    "shadow": "4px 3px 16px rgba(0,0,0,0.15)",
    "maxWidth": "16px",
    "gap": "16px"
  },
  "tooltip": {
    "borderRadius": "24px",
    "paddingX": "12px",
    "paddingY": "24px",
    "shadow": "4px 5px 16px rgba(0,0,0,0.13)",
    "fontSize": "2px"
  },
  "badge": {
    "borderRadius": "16px",
    "paddingX": "12px",
    "paddingY": "12px",
    "fontSize": "2px",
