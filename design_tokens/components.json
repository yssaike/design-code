{
  "button": {
    "borderRadius": "24px",
    "paddingX": "4px",
    "paddingY": "24px",
    "shadow": "4px 5px 21px rgba(0,0,0,0.18)",
    "fontSize": "2px",
    "fontWeight": "2px",
    "gap": "4px"
  },
  "input": {
    "borderRadius": "2px",
    "paddingX": "24px",
    "paddingY": "4px",
    "borderWidth": "1px",
    "fontSize": "12px",
    "shadow": "3px 3px 8px rgba(0,0,0,0.14)"
  },
  "card": {
    "borderRadius": "24px",
    "padding": "16px",
    "shadow": "4px 5px 24px rgba(0,0,0,0.1)",
    "borderWidth": "16px",
    "gap": "16px"
  },
  "modal": {
    "borderRadius": "12px",
    "padding": "16px",
    "shadow": "2px 7px 23px rgba(0,0,0,0.1)",
    "maxWidth": "2px",
    "gap": "16px"
  },
  "tooltip": {
    "borderRadius": "24px",
    "paddingX": "20px",
    "paddingY": "16px",
    "shadow": "1px 2px 5px rgba(0,0,0,0.05)",
