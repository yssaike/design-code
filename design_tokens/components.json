{
  "button": {
    "borderRadius": "9999px",
    "paddingX": "24px",
    "paddingY": "4px",
    "shadow": "0px 1px 12px rgba(0,0,0,0.17)",
    "fontSize": "16px",
    "fontWeight": "12px",
    "gap": "24px"
  },
  "input": {
    "borderRadius": "6px",
    "paddingX": "8px",
    "paddingY": "24px",
    "borderWidth": "1px",
    "fontSize": "8px",
    "shadow": "4px 4px 19px rgba(0,0,0,0.08)"
  },
  "card": {
    "borderRadius": "4px",
    "padding": "24px",
    "shadow": "4px 5px 5px rgba(0,0,0,0.08)",
    "borderWidth": "4px",
    "gap": "4px"
  },
  "modal": {
    "borderRadius": "8px",
    "padding": "4px",
    "shadow": "4px 2px 21px rgba(0,0,0,0.19)",
    "maxWidth": "12px",
    "gap": "12px"
  },
  "tooltip": {
    "borderRadius": "4px",
    "paddingX": "4px",
    "paddingY": "16px",
    "shadow": "0px 5px 14px rgba(0,0,0,0.09)",
