{
  "button": {
    "borderRadius": "9999px",
    "paddingX": "24px",
    "paddingY": "4px",
    "shadow": "4px 8px 6px rgba(0,0,0,0.14)",
    "fontSize": "1px",
    "fontWeight": "12px",
    "gap": "24px"
  },
  "input": {
    "borderRadius": "16px",
    "paddingX": "8px",
    "paddingY": "16px",
    "borderWidth": "1px",
    "fontSize": "2px",
    "shadow": "3px 5px 10px rgba(0,0,0,0.16)"
  },
  "card": {
    "borderRadius": "4px",
    "padding": "16px",
    "shadow": "3px 4px 23px rgba(0,0,0,0.19)",
    "borderWidth": "4px",
    "gap": "20px"
  },
  "modal": {
    "borderRadius": "8px",
