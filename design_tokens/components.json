{
  "button": {
    "borderRadius": "9999px",
    "paddingX": "4px",
    "paddingY": "16px",
    "shadow": "4px 5px 10px rgba(0,0,0,0.14)",
    "fontSize": "16px",
    "fontWeight": "16px",
    "gap": "20px"
  },
  "input": {
    "borderRadius": "6px",
    "paddingX": "8px",
    "paddingY": "4px",
    "borderWidth": "16px",
    "fontSize": "4px",
