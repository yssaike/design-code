{
  "button": {
    "borderRadius": "16px",
    "paddingX": "24px",
    "paddingY": "4px",
    "shadow": "4px 5px 21px rgba(0,0,0,0.18)",
    "fontSize": "2px",
    "fontWeight": "16px",
    "gap": "4px"
  },
  "input": {
    "borderRadius": "16px",
    "paddingX": "24px",
    "paddingY": "8px",
    "borderWidth": "1px",
    "fontSize": "1px",
    "shadow": "2px 8px 4px rgba(0,0,0,0.15)"
  },
  "card": {
    "borderRadius": "24px",
    "padding": "20px",
    "shadow": "1px 6px 14px rgba(0,0,0,0.13)",
    "borderWidth": "2px",
    "gap": "20px"
  },
  "modal": {
    "borderRadius": "2px",
    "padding": "4px",
    "shadow": "2px 1px 24px rgba(0,0,0,0.17)",
    "maxWidth": "12px",
    "gap": "24px"
  },
  "tooltip": {
    "borderRadius": "8px",
    "paddingX": "4px",
    "paddingY": "24px",
    "shadow": "3px 3px 14px rgba(0,0,0,0.07)",
