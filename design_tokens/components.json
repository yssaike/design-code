{
  "button": {
    "borderRadius": "9999px",
    "paddingX": "8px",
    "paddingY": "12px",
    "shadow": "2px 1px 8px rgba(0,0,0,0.1)",
    "fontSize": "16px",
    "fontWeight": "16px",
    "gap": "20px"
  },
  "input": {
    "borderRadius": "6px",
    "paddingX": "8px",
    "paddingY": "8px",
    "borderWidth": "16px",
    "fontSize": "1px",
    "shadow": "3px 8px 22px rgba(0,0,0,0.04)"
  },
  "card": {
    "borderRadius": "4px",
    "padding": "20px",
    "shadow": "4px 5px 5px rgba(0,0,0,0.08)",
    "borderWidth": "8px",
    "gap": "4px"
  },
  "modal": {
    "borderRadius": "8px",
    "padding": "4px",
    "shadow": "1px 2px 22px rgba(0,0,0,0.12)",
    "maxWidth": "4px",
    "gap": "12px"
  },
  "tooltip": {
    "borderRadius": "6px",
    "paddingX": "24px",
    "paddingY": "16px",
    "shadow": "0px 5px 14px rgba(0,0,0,0.09)",
    "fontSize": "1px"
  },
  "badge": {
    "borderRadius": "16px",
    "paddingX": "8px",
    "paddingY": "24px",
    "fontSize": "4px",
    "fontWeight": "4px"
  },
  "avatar": {
    "borderRadius": "12px",
    "borderWidth": "1px",
    "shadow": "0px 7px 24px rgba(0,0,0,0.12)",
    "size": "1px"
  },
  "dropdown": {
    "borderRadius": "2px",
    "padding": "4px",
    "shadow": "0px 8px 6px rgba(0,0,0,0.04)",
    "itemPadding": "20px",
    "gap": "12px"
  },
  "tabs": {
    "borderRadius": "6px",
    "paddingX": "8px",
    "paddingY": "12px",
    "gap": "20px",
    "fontSize": "1px",
    "fontWeight": "2px"
  },
  "checkbox": {
    "borderRadius": "12px",
    "size": "2px",
    "borderWidth": "4px",
    "gap": "12px"
