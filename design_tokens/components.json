{
  "button": {
    "borderRadius": "24px",
    "paddingX": "4px",
    "paddingY": "24px",
    "shadow": "4px 5px 21px rgba(0,0,0,0.18)",
    "fontSize": "2px",
    "fontWeight": "1px",
    "gap": "4px"
  },
  "input": {
    "borderRadius": "24px",
    "paddingX": "24px",
    "paddingY": "4px",
    "borderWidth": "1px",
    "fontSize": "12px",
