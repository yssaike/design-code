  },
  "avatar": {
    "borderRadius": "24px",
    "borderWidth": "12px",
    "shadow": "4px 7px 5px rgba(0,0,0,0.06)",
    "size": "12px"
  },
  "dropdown": {
    "borderRadius": "12px",
    "padding": "24px",
    "shadow": "3px 1px 12px rgba(0,0,0,0.18)",
    "itemPadding": "24px",
    "gap": "20px"
  },
  "tabs": {
    "borderRadius": "4px",
    "paddingX": "8px",
    "paddingY": "12px",
    "gap": "20px",
    "fontSize": "8px",
    "fontWeight": "16px"
  },
  "checkbox": {
    "borderRadius": "6px",
    "size": "1px",
    "borderWidth": "4px",
    "gap": "24px"
