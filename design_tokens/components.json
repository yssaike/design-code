{
  "button": {
    "borderRadius": "9999px",
    "paddingX": "20px",
    "paddingY": "4px",
    "shadow": "3px 8px 5px rgba(0,0,0,0.05)",
    "fontSize": "2px",
    "fontWeight": "12px",
    "gap": "12px"
  },
  "input": {
    "borderRadius": "16px",
    "paddingX": "24px",
    "paddingY": "12px",
    "borderWidth": "1px",
    "fontSize": "1px",
    "shadow": "2px 1px 5px rgba(0,0,0,0.15)"
  },
  "card": {
    "borderRadius": "24px",
    "padding": "8px",
    "shadow": "3px 1px 8px rgba(0,0,0,0.11)",
    "borderWidth": "8px",
    "gap": "12px"
  },
  "modal": {
    "borderRadius": "6px",
    "padding": "24px",
    "shadow": "4px 8px 23px rgba(0,0,0,0.09)",
    "maxWidth": "8px",
    "gap": "12px"
  },
  "tooltip": {
    "borderRadius": "2px",
    "paddingX": "12px",
    "paddingY": "20px",
    "shadow": "3px 6px 21px rgba(0,0,0,0.11)",
    "fontSize": "1px"
  },
  "badge": {
    "borderRadius": "6px",
    "paddingX": "12px",
    "paddingY": "20px",
    "fontSize": "1px",
    "fontWeight": "16px"
  },
  "avatar": {
    "borderRadius": "16px",
    "borderWidth": "8px",
    "shadow": "4px 5px 5px rgba(0,0,0,0.11)",
    "size": "12px"
  },
  "dropdown": {
    "borderRadius": "8px",
    "padding": "4px",
    "shadow": "2px 3px 10px rgba(0,0,0,0.12)",
    "itemPadding": "4px",
    "gap": "8px"
  },
  "tabs": {
    "borderRadius": "9999px",
    "paddingX": "12px",
    "paddingY": "16px",
    "gap": "12px",
    "fontSize": "1px",
    "fontWeight": "4px"
  },
  "checkbox": {
    "borderRadius": "24px",
    "size": "2px",
    "borderWidth": "8px",
    "gap": "12px"
  }
}