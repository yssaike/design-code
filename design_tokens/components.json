{
  "button": {
    "borderRadius": "24px",
    "paddingX": "16px",
    "paddingY": "24px",
    "shadow": "1px 1px 6px rgba(0,0,0,0.12)",
    "fontSize": "2px",
    "fontWeight": "1px",
    "gap": "4px"
  },
  "input": {
    "borderRadius": "24px",
    "paddingX": "24px",
    "paddingY": "16px",
    "borderWidth": "16px",
    "fontSize": "16px",
    "shadow": "0px 7px 17px rgba(0,0,0,0.12)"
  },
  "card": {
    "borderRadius": "2px",
    "padding": "20px",
    "shadow": "3px 6px 13px rgba(0,0,0,0.18)",
    "borderWidth": "16px",
    "gap": "4px"
  },
  "modal": {
    "borderRadius": "8px",
    "padding": "8px",
    "shadow": "3px 2px 4px rgba(0,0,0,0.1)",
