{
  "button": {
    "borderRadius": "16px",
    "paddingX": "20px",
    "paddingY": "16px",
    "shadow": "2px 4px 16px rgba(0,0,0,0.11)",
    "fontSize": "16px",
    "fontWeight": "1px",
    "gap": "12px"
  },
  "input": {
    "borderRadius": "16px",
    "paddingX": "24px",
    "paddingY": "8px",
    "borderWidth": "1px",
    "fontSize": "2px",
    "shadow": "3px 3px 8px rgba(0,0,0,0.14)"
  },
  "card": {
    "borderRadius": "24px",
    "padding": "12px",
    "shadow": "4px 4px 18px rgba(0,0,0,0.16)",
    "borderWidth": "2px",
    "gap": "4px"
  },
  "modal": {
    "borderRadius": "12px",
    "padding": "12px",
    "shadow": "1px 2px 13px rgba(0,0,0,0.17)",
    "maxWidth": "4px",
    "gap": "20px"
  },
  "tooltip": {
    "borderRadius": "24px",
    "paddingX": "12px",
    "paddingY": "8px",
    "shadow": "4px 4px 5px rgba(0,0,0,0.15)",
