{
  "button": {
    "borderRadius": "8px",
    "paddingX": "16px",
    "paddingY": "24px",
    "shadow": "1px 7px 7px rgba(0,0,0,0.11)",
    "fontSize": "2px",
    "fontWeight": "1px",
    "gap": "4px"
  },
  "input": {
    "borderRadius": "24px",
    "paddingX": "24px",
    "paddingY": "20px",
    "borderWidth": "16px",
