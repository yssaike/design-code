  },
  "dropdown": {
    "borderRadius": "2px",
    "padding": "4px",
    "shadow": "1px 1px 4px rgba(0,0,0,0.19)",
    "itemPadding": "4px",
    "gap": "12px"
  },
  "tabs": {
    "borderRadius": "12px",
    "paddingX": "8px",
    "paddingY": "12px",
    "gap": "8px",
    "fontSize": "1px",
    "fontWeight": "2px"
  },
  "checkbox": {
    "borderRadius": "12px",
    "size": "2px",
    "borderWidth": "4px",
    "gap": "12px"
  }
