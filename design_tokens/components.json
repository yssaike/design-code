{
  "button": {
    "borderRadius": "4px",
    "paddingX": "12px",
    "paddingY": "20px",
    "shadow": "4px 3px 24px rgba(0,0,0,0.18)",
    "fontSize": "2px",
    "fontWeight": "16px",
    "gap": "4px"
  },
  "input": {
    "borderRadius": "9999px",
    "paddingX": "24px",
    "paddingY": "8px",
