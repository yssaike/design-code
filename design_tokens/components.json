{
  "button": {
    "borderRadius": "9999px",
    "paddingX": "20px",
    "paddingY": "4px",
    "shadow": "4px 8px 6px rgba(0,0,0,0.14)",
    "fontSize": "12px",
    "fontWeight": "12px",
    "gap": "20px"
  },
  "input": {
    "borderRadius": "16px",
    "paddingX": "16px",
    "paddingY": "16px",
    "borderWidth": "1px",
    "fontSize": "8px",
    "shadow": "2px 4px 8px rgba(0,0,0,0.2)"
  },
  "card": {
    "borderRadius": "4px",
    "padding": "16px",
    "shadow": "3px 1px 8px rgba(0,0,0,0.11)",
    "borderWidth": "2px",
    "gap": "20px"
  },
  "modal": {
    "borderRadius": "8px",
    "padding": "4px",
    "shadow": "3px 2px 9px rgba(0,0,0,0.17)",
    "maxWidth": "8px",
    "gap": "12px"
  },
  "tooltip": {
    "borderRadius": "4px",
    "paddingX": "4px",
    "paddingY": "20px",
    "shadow": "0px 5px 14px rgba(0,0,0,0.09)",
    "fontSize": "1px"
  },
  "badge": {
    "borderRadius": "24px",
    "paddingX": "16px",
    "paddingY": "12px",
    "fontSize": "12px",
    "fontWeight": "16px"
  },
  "avatar": {
    "borderRadius": "24px",
    "borderWidth": "8px",
    "shadow": "2px 3px 6px rgba(0,0,0,0.2)",
    "size": "8px"
  },
  "dropdown": {
    "borderRadius": "16px",
    "padding": "12px",
    "shadow": "2px 1px 9px rgba(0,0,0,0.15)",
    "itemPadding": "20px",
    "gap": "24px"
  },
  "tabs": {
    "borderRadius": "6px",
    "paddingX": "8px",
    "paddingY": "24px",
    "gap": "16px",
    "fontSize": "12px",
    "fontWeight": "12px"
  },
  "checkbox": {
    "borderRadius": "24px",
    "size": "12px",
    "borderWidth": "8px",
    "gap": "20px"
  }
