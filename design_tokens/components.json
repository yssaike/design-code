{
  "button": {
    "borderRadius": "24px",
    "paddingX": "12px",
    "paddingY": "16px",
    "shadow": "4px 5px 21px rgba(0,0,0,0.18)",
    "fontSize": "1px",
    "fontWeight": "4px",
    "gap": "8px"
  },
  "input": {
    "borderRadius": "16px",
    "paddingX": "20px",
    "paddingY": "12px",
    "borderWidth": "8px",
    "fontSize": "4px",
    "shadow": "3px 2px 9px rgba(0,0,0,0.06)"
  },
  "card": {
    "borderRadius": "24px",
    "padding": "4px",
    "shadow": "1px 3px 24px rgba(0,0,0,0.18)",
    "borderWidth": "12px",
    "gap": "4px"
  },
  "modal": {
    "borderRadius": "9999px",
    "padding": "8px",
    "shadow": "0px 3px 15px rgba(0,0,0,0.2)",
    "maxWidth": "8px",
    "gap": "20px"
  },
  "tooltip": {
    "borderRadius": "2px",
    "paddingX": "4px",
    "paddingY": "12px",
    "shadow": "3px 1px 20px rgba(0,0,0,0.16)",
    "fontSize": "1px"
  },
  "badge": {
    "borderRadius": "12px",
    "paddingX": "8px",
    "paddingY": "24px",
    "fontSize": "8px",
