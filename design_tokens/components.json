{
  "button": {
    "borderRadius": "2px",
    "paddingX": "16px",
    "paddingY": "16px",
    "shadow": "3px 4px 12px rgba(0,0,0,0.12)",
    "fontSize": "16px",
    "fontWeight": "16px",
    "gap": "12px"
  },
  "input": {
    "borderRadius": "2px",
    "paddingX": "12px",
    "paddingY": "8px",
    "borderWidth": "16px",
    "fontSize": "4px",
    "shadow": "3px 7px 7px rgba(0,0,0,0.16)"
  },
  "card": {
    "borderRadius": "8px",
    "padding": "4px",
    "shadow": "1px 5px 22px rgba(0,0,0,0.08)",
    "borderWidth": "4px",
    "gap": "8px"
  },
  "modal": {
    "borderRadius": "8px",
    "padding": "20px",
    "shadow": "4px 4px 17px rgba(0,0,0,0.15)",
