{
  "button": {
    "borderRadius": "16px",
    "paddingX": "24px",
    "paddingY": "4px",
    "shadow": "3px 8px 5px rgba(0,0,0,0.05)",
    "fontSize": "2px",
    "fontWeight": "1px",
    "gap": "12px"
  },
  "input": {
    "borderRadius": "16px",
    "paddingX": "4px",
    "paddingY": "24px",
    "borderWidth": "2px",
    "fontSize": "16px",
    "shadow": "1px 6px 4px rgba(0,0,0,0.19)"
  },
  "card": {
    "borderRadius": "12px",
    "padding": "8px",
    "shadow": "0px 5px 20px rgba(0,0,0,0.08)",
    "borderWidth": "2px",
    "gap": "20px"
  },
  "modal": {
    "borderRadius": "6px",
    "padding": "4px",
    "shadow": "2px 4px 16px rgba(0,0,0,0.13)",
