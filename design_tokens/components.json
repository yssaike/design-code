  },
  "dropdown": {
    "borderRadius": "24px",
    "padding": "4px",
    "shadow": "0px 3px 15px rgba(0,0,0,0.08)",
    "itemPadding": "4px",
    "gap": "8px"
  },
  "tabs": {
    "borderRadius": "2px",
    "paddingX": "8px",
    "paddingY": "4px",
    "gap": "16px",
