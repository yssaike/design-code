{
  "button": {
    "borderRadius": "16px",
    "paddingX": "24px",
    "paddingY": "4px",
    "shadow": "4px 5px 21px rgba(0,0,0,0.18)",
    "fontSize": "8px",
    "fontWeight": "4px",
    "gap": "8px"
  },
  "input": {
    "borderRadius": "16px",
    "paddingX": "24px",
    "paddingY": "4px",
    "borderWidth": "1px",
    "fontSize": "12px",
