  },
  "dropdown": {
    "borderRadius": "4px",
    "padding": "20px",
    "shadow": "2px 1px 8px rgba(0,0,0,0.1)",
    "itemPadding": "4px",
    "gap": "24px"
  },
  "tabs": {
    "borderRadius": "8px",
    "paddingX": "20px",
    "paddingY": "24px",
    "gap": "20px",
    "fontSize": "8px",
    "fontWeight": "1px"
  },
  "checkbox": {
    "borderRadius": "8px",
    "size": "2px",
    "borderWidth": "2px",
    "gap": "4px"
