{
  "button": {
    "borderRadius": "24px",
    "paddingX": "8px",
    "paddingY": "16px",
    "shadow": "4px 5px 21px rgba(0,0,0,0.18)",
    "fontSize": "2px",
    "fontWeight": "2px",
    "gap": "4px"
  },
  "input": {
    "borderRadius": "2px",
    "paddingX": "12px",
    "paddingY": "8px",
    "borderWidth": "4px",
    "fontSize": "4px",
    "shadow": "3px 2px 9px rgba(0,0,0,0.06)"
  },
  "card": {
    "borderRadius": "4px",
    "padding": "16px",
    "shadow": "1px 3px 24px rgba(0,0,0,0.18)",
    "borderWidth": "16px",
    "gap": "4px"
  },
  "modal": {
    "borderRadius": "9999px",
    "padding": "16px",
    "shadow": "1px 8px 11px rgba(0,0,0,0.1)",
