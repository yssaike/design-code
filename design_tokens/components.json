{
  "button": {
    "borderRadius": "9999px",
    "paddingX": "8px",
    "paddingY": "12px",
    "shadow": "0px 1px 12px rgba(0,0,0,0.17)",
    "fontSize": "16px",
    "fontWeight": "16px",
    "gap": "24px"
  },
  "input": {
    "borderRadius": "6px",
    "paddingX": "4px",
    "paddingY": "24px",
    "borderWidth": "4px",
    "fontSize": "1px",
    "shadow": "3px 8px 22px rgba(0,0,0,0.04)"
  },
  "card": {
    "borderRadius": "4px",
    "padding": "20px",
    "shadow": "4px 5px 5px rgba(0,0,0,0.08)",
    "borderWidth": "8px",
    "gap": "4px"
  },
  "modal": {
    "borderRadius": "8px",
    "padding": "4px",
    "shadow": "3px 5px 7px rgba(0,0,0,0.14)",
    "maxWidth": "1px",
    "gap": "12px"
  },
  "tooltip": {
    "borderRadius": "6px",
    "paddingX": "24px",
    "paddingY": "16px",
    "shadow": "0px 5px 14px rgba(0,0,0,0.09)",
