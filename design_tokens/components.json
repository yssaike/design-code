{
  "button": {
    "borderRadius": "4px",
    "paddingX": "4px",
    "paddingY": "8px",
    "shadow": "3px 4px 4px rgba(0,0,0,0.09)",
    "fontSize": "16px",
    "fontWeight": "16px",
    "gap": "12px"
  },
  "input": {
    "borderRadius": "6px",
    "paddingX": "12px",
    "paddingY": "4px",
    "borderWidth": "1px",
    "fontSize": "2px",
    "shadow": "3px 7px 17px rgba(0,0,0,0.11)"
  },
  "card": {
    "borderRadius": "24px",
    "padding": "8px",
    "shadow": "4px 3px 24px rgba(0,0,0,0.12)",
    "borderWidth": "2px",
    "gap": "20px"
  },
  "modal": {
    "borderRadius": "8px",
    "padding": "12px",
    "shadow": "2px 1px 13px rgba(0,0,0,0.07)",
    "maxWidth": "12px",
    "gap": "4px"
  },
  "tooltip": {
    "borderRadius": "24px",
    "paddingX": "20px",
    "paddingY": "16px",
