{
  "button": {
    "borderRadius": "8px",
    "paddingX": "4px",
    "paddingY": "12px",
    "shadow": "1px 6px 23px rgba(0,0,0,0.16)",
    "fontSize": "16px",
    "fontWeight": "1px",
    "gap": "4px"
  },
  "input": {
    "borderRadius": "2px",
    "paddingX": "20px",
    "paddingY": "8px",
    "borderWidth": "8px",
    "fontSize": "2px",
    "shadow": "4px 5px 23px rgba(0,0,0,0.19)"
  },
  "card": {
    "borderRadius": "4px",
    "padding": "4px",
